PORT=5000
# Local: mongodb://localhost:27017/tour-agreement
# Atlas: mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/tour-agreement?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/tour-agreement
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Optional: used by npm run create-admin (defaults: adim@gmail.com / Admin123)
ADMIN_EMAIL=adim@gmail.com
ADMIN_PASSWORD=Admin123

# Email (nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your_app_password

# MEGA — PDF uploads (same login as mega.nz). Test: npm run test-mega
# If login fails: wrong password, extra spaces, or 2FA (may block megajs — try a dedicated account without 2FA).
MEGA_EMAIL=your@mega.account
MEGA_PASSWORD=your_mega_password
